# Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# OpenAI API key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI model
OPENAI_MODEL=gpt-5.4-nano

# Server port
PORT=8080

# Google Slides publish-to-web embed URL
# In Google Slides: File -> Share -> Publish to web -> Embed tab -> Publish ->
# copy the src URL from the iframe. Looks like:
# https://docs.google.com/presentation/d/e/<PUB_ID>/embed?start=false&loop=false&delayms=3000
WORKSHOP_SLIDES_EMBED_URL=
